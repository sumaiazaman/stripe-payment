# Stripe API Keys
# Get these from: https://dashboard.stripe.com/developers/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY

# Stripe Webhook Secret
# Local:      Run `stripe listen --forward-to localhost:3000/api/webhook` and copy the printed whsec_...
# Production: Get from Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET
